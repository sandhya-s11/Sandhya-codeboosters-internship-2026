        "print(f'Duplicate rows: {df.duplicated().sum()}')\n",
        "\n",
        "# Show which rows are duplicates\n",
        "print('\\nDuplicate rows:')\n",
        "print(df[df.duplicated(keep=False)][['order_id','customer_name','product','order_date']].head(6))\n",
        "# keep=False marks ALL copies of a duplicate (not just the second+)\n",
        "# This lets us SEE both the original and the duplicate before removing\n",
        "\n",
        "# Remove exact duplicate rows\n",
        "df.drop_duplicates(inplace=True)\n",
        "# drop_duplicates() removes rows that are IDENTICAL in ALL columns\n",
        "# The first occurrence is kept; subsequent copies are removed\n",
        "\n",
        "print(f'\\nAfter deduplication: {len(df)} rows')\n",
        "print(f'Rows removed: {len(raw_df) - len(df)}')"
      ]
    },
