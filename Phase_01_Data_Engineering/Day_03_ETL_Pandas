        "# ============================================================\n",
        "# CELL 8 — Fix #4 & #5: Text Standardization + Wrong Category\n",
        "# ============================================================\n",
        "\n",
        "# Fix #4: Standardize customer names to Title Case\n",
        "print('Before standardization:', df['customer_name'].unique()[:6])\n",
        "\n",
        "df['customer_name'] = (\n",
        "    df['customer_name']\n",
