        "# ============================================================\n",
        "\n",
        "raw_df = pd.read_csv('messy_sales_data.csv')\n",
        "# We store the RAW data in 'raw_df'\n",
        "# ETL best practice: NEVER modify raw data\n",
        "# Always work on a copy so you can go back to the original\n",
        "\n",
        "print(f'Raw data loaded: {raw_df.shape[0]} rows, {raw_df.shape[1]} columns')\n",
