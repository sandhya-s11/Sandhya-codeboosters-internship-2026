      "source": [
        "# ============================================================\n",
        "# CELL 4 — Create a working copy (ETL best practice)\n",
        "# ============================================================\n",
        "\n",
        "df = raw_df.copy()\n",
        "# .copy() creates a completely independent copy of the DataFrame\n",
        "# Without .copy(), df and raw_df would point to the same data\n",
        "# Modifying df would also modify raw_df — we don't want that\n",
        "# This is the most important ETL hygiene rule\n",
        "\n",
        "print(f'Working copy created: {df.shape}')\n",
        "print('raw_df is untouched — we can always reset by running df = raw_df.copy()')"
      ]
    },
    {
      "cell_type": "code",
      "id": "d3-010",
      "metadata": {
        "id": "d3-010"
      },
      "execution_count": null,
      "outputs": [],
      "source": [
        "# ============================================================\n",
        "# CELL 5 — Fix #1: Handle Missing Values\n",
        "# ============================================================\n",
        "\n",
        "print('Before fixing nulls:', df.isnull().sum().sum(), 'total missing values')\n",
        "\n",
        "# Fix missing customer_name — fill with 'Unknown Customer'\n",
        "df['customer_name'].fillna('Unknown Customer', inplace=True)\n",
        "# fillna() replaces NaN values with the given value\n",
        "# inplace=True modifies df directly instead of returning a new DataFrame\n",
        "# For customer names, 'Unknown Customer' is better than dropping the row\n",
        "# because we still have the order data (product, price, etc.)\n",
        "\n",
        "# Fix missing quantity — fill with median (robust to outliers)\n",
        "median_qty = df['quantity'].median()\n",
        "# .median() calculates the middle value — better than mean for numeric fills\n",
        "# because median is not affected by extreme outliers\n",
        "df['quantity'].fillna(median_qty, inplace=True)\n",
        "print(f'  Filled missing quantity with median: {median_qty}')\n",
        "\n",
        "# Fix missing category\n",
        "df['category'].fillna('Uncategorized', inplace=True)\n",
        "\n",
        "print('After fixing nulls:', df.isnull().sum().sum(), 'total missing values')\n",
        "# Should be 0"
      ]
    },
